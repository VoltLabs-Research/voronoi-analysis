{
  "workflow": {
    "nodes": [
      {
        "id": "plugin-metadata",
        "type": "modifier",
        "position": {
          "x": 240,
          "y": 160
        },
        "data": {
          "modifier": {
            "name": "Voronoi Analysis",
            "key": "voronoi-analysis",
            "icon": "HiCube",
            "author": "Rodolfo Herrera",
            "license": "MIT",
            "version": "1.0.5",
            "homepage": "https://github.com/rodyherrera/Volterra",
            "description": "Computa la teselacion de Voronoi por atomo (numero de coordinacion topologico, volumen atomico y radio de cavidad) usando una implementacion interna de clipping por semi-espacios."
          }
        }
      },
      {
        "id": "plugin-arguments",
        "type": "arguments",
        "position": {
          "x": 528,
          "y": 208
        },
        "data": {
          "arguments": {
            "arguments": [
              {
                "argument": "cutoff",
                "type": "number",
                "label": "Cutoff Radius",
                "default": 0,
                "min": 0,
                "step": 0.1
              },
              {
                "argument": "edgeThreshold",
                "type": "number",
                "label": "Edge Threshold",
                "default": 0,
                "min": 0,
                "step": 0.01
              },
              {
                "argument": "faceThreshold",
                "type": "number",
                "label": "Face Area Threshold",
                "default": 0,
                "min": 0,
                "step": 0.01
              },
              {
                "argument": "useRadii",
                "type": "boolean",
                "label": "Use Particle Radii (Radical Voronoi)",
                "default": false
              },
              {
                "argument": "onlySelected",
                "type": "boolean",
                "label": "Only Selected Atoms",
                "default": false
              }
            ]
          }
        }
      },
      {
        "id": "trajectory-context",
        "type": "context",
        "position": {
          "x": 816,
          "y": 160
        },
        "data": {
          "context": {
            "source": "trajectory_dumps"
          }
        }
      },
      {
        "id": "foreach-trajectory-dumps",
        "type": "forEach",
        "position": {
          "x": 1088,
          "y": 208
        },
        "data": {
          "forEach": {
            "iterableSource": "{{ trajectory-context.trajectory_dumps }}"
          }
        }
      },
      {
        "id": "analysis-entrypoint",
        "type": "entrypoint",
        "position": {
          "x": 1392,
          "y": 208
        },
        "data": {
          "entrypoint": {
            "type": "executable",
            "binary": "voronoi-analysis",
            "binaryObjectPath": "__UPLOAD_BINARY_OBJECT_PATH__",
            "binaryFileName": "voronoi-analysis",
            "arguments": "{{ foreach-trajectory-dumps.currentValue.path }} {{ foreach-trajectory-dumps.outputPath }} {{ plugin-arguments.as_str }}",
            "timeout": -1
          }
        }
      },
      {
        "id": "primary-exposure",
        "type": "exposure",
        "position": {
          "x": 1712,
          "y": 208
        },
        "data": {
          "exposure": {
            "name": "Voronoi Analysis",
            "icon": "HiCube",
            "results": "voronoi.parquet",
            "iterable": "",
            "properties": [
              { "key": "mean_face_order", "label": "Mean Face Order", "type": "double" },
              { "key": "max_face_order_observed", "label": "Max Face Order Observed", "type": "int" },
              { "key": "polyhedra_mesh_count", "label": "Polyhedra Mesh Count", "type": "int" },
              { "key": "mean_atomic_volume", "label": "Mean Atomic Volume", "type": "double" },
              { "key": "mean_coordination", "label": "Mean Coordination", "type": "double" }
            ]
          }
        }
      },
      {
        "id": "voronoi-model-exposure",
        "type": "exposure",
        "position": {
          "x": 1712,
          "y": 336
        },
        "data": {
          "exposure": {
            "name": "Voronoi Model",
            "icon": "HiCube",
            "results": "atoms.parquet",
            "iterable": "",
            "properties": [
              {
                "key": "coordination",
                "label": "Coordination number",
                "type": "int"
              },
              {
                "key": "atomic_volume",
                "label": "Atomic volume",
                "type": "double"
              },
              {
                "key": "cavity_radius",
                "label": "Cavity radius",
                "type": "double"
              },
              {
                "key": "face_indices",
                "label": "Face indices (Voronoi index vector)",
                "type": "list<double>"
              }
            ]
          }
        }
      },
      {
        "id": "voronoi-model-export",
        "type": "export",
        "position": {
          "x": 2032,
          "y": 336
        },
        "data": {
          "export": {
            "exporter": "AtomisticExporter",
            "type": "glb"
          }
        }
      }
    ],
    "edges": [
      {
        "id": "edge-metadata-arguments",
        "source": "plugin-metadata",
        "sourceHandle": "output",
        "target": "plugin-arguments",
        "targetHandle": "input"
      },
      {
        "id": "edge-arguments-context",
        "source": "plugin-arguments",
        "sourceHandle": "output",
        "target": "trajectory-context",
        "targetHandle": "input"
      },
      {
        "id": "edge-context-foreach",
        "source": "trajectory-context",
        "sourceHandle": "output",
        "target": "foreach-trajectory-dumps",
        "targetHandle": "input"
      },
      {
        "id": "edge-foreach-entrypoint",
        "source": "foreach-trajectory-dumps",
        "sourceHandle": "output",
        "target": "analysis-entrypoint",
        "targetHandle": "input"
      },
      {
        "id": "edge-entrypoint-primary-exposure",
        "source": "analysis-entrypoint",
        "sourceHandle": "output",
        "target": "primary-exposure",
        "targetHandle": "input"
      },
      {
        "id": "edge-entrypoint-voronoi-model-exposure",
        "source": "analysis-entrypoint",
        "sourceHandle": "output",
        "target": "voronoi-model-exposure",
        "targetHandle": "input"
      },
      {
        "id": "edge-voronoi-model-exposure-export",
        "source": "voronoi-model-exposure",
        "sourceHandle": "output",
        "target": "voronoi-model-export",
        "targetHandle": "input"
      }
    ]
  }
}
